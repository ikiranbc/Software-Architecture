{
  "name": "hotel-booking-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "node scripts/dev.mjs",
    "seed:dev": "node scripts/seed-dev-data.mjs",
    "fix:unblock-user": "node scripts/unblock-user.mjs",
    "dev:client": "npm run dev -w apps/client",
    "dev:gateway": "npm run dev -w apps/api-gateway",
    "dev:auth": "npm run dev -w services/auth-service",
    "dev:user": "npm run dev -w services/user-service",
    "dev:hotel": "npm run dev -w services/hotel-service",
    "dev:booking": "npm run dev -w services/booking-service",
    "dev:wallet": "npm run dev -w services/wallet-service",
    "dev:admin": "npm run dev -w services/admin-service",
    "dev:notification": "npm run dev -w services/notification-service",
    "check": "node scripts/check-js.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^4.5.14"
  }
}
